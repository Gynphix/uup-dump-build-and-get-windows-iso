;-----------------------------------------------------------------------------
; Driver "service" installation settings
;-----------------------------------------------------------------------------
[Service]
DisplayName    = %Service.Displayname%
ServiceType    = 1 ;%SERVICE_KERNEL_DRIVER%
StartType      = 3 ;%SERVICE_DEMAND_START%
ErrorControl   = 1 ;%SERVICE_ERROR_NORMAL%
ServiceBinary  = %12%\icea.sys
LoadOrderGroup = NDIS
AddReg         = Service_AddReg

[Service_AddReg]
HKR,, BootFlags, 0x00010001, 0x1

;-----------------------------------------------------------------------------
; Event Log settings
;-----------------------------------------------------------------------------
[EventLog]
AddReg = AddEventLog

[CopyFiles]
icea.sys,,,2

[CoInK.reg]
HKR,, CoInstallFlag, 0x00010001, 0x20280040

[CoInKPM.reg]
HKR,, CoInstallFlag, 0x00010001, 0x20280048

[MessageDll.CopyFiles]
iceamsg.dll,,,2

;-----------------------------------------------------------------------------
; DestinationDirs
;-----------------------------------------------------------------------------
[DestinationDirs]
CopyFiles            = 12
DefaultDestDir       = 11
Uninstall.CopyFiles  = 11
MessageDll.CopyFiles = 11

[SourceDisksNames]
1 = %DiskName%,,,

