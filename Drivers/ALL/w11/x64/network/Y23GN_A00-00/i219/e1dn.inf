[UninstallW2.reg]
HKR,,                                                   UniversalInstall,       0x00010001, 1
HKR, Prounstl\SupportedDevices\8086, 550A, 0, "550A"
HKR, Prounstl\SupportedDevices\8086, 550B, 0, "550B"
HKR, Prounstl\SupportedDevices\8086, 550C, 0, "550C"
