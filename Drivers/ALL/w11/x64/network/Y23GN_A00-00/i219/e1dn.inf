;===============================================================================
;
;                         WINDOWS 10 64-BIT PLATFORMS
;
;===============================================================================
;------------------------------------------------------------------------------
; Intel(R) Ethernet Connection I219
;------------------------------------------------------------------------------

[I219.10.0.1..22000]
Characteristics     = 0x84 ; NCF_HAS_UI | NCF_PHYSICAL
BusType             = 5 ; PCI
*PhysicalMediaType  = 14  ; NdisPhysicalMedium802_3
*IfType             = 6 ;IF_TYPE_ETHERNET_CSMACD
*MediaType          = 0  ;NdisMedium802_3
*IfConnectorPresent = 1 ; BOOLEAN
*ConnectionType     = 1 ; NET_IF_CONNECTION_TYPE
*DirectionType      = 0 ; NET_IF_DIRECTION_TYPE
*AccessType         = 2 ; NET_IF_ACCESS_TYPE
*HardwareLoopback   = 0 ; BOOLEAN
AddReg              = e1dn.reg
AddReg              = TcpSeg.reg
AddReg              = Copper.reg
AddReg              = Powermgmt.reg
AddReg              = ULP.reg
AddReg              = EEE.reg
AddReg              = Jumbopacket.reg
AddReg              = ProtocolOffload.reg
AddReg              = RTD3.reg
AddReg              = IntelANSVlanID.reg
AddReg              = CoInKS.reg
AddReg              = UninstallW2.reg
CopyFiles           = win10.CopyFiles, MessageDll.CopyFiles

[I219.10.0.1..22000.Services]
AddService = e1dnexpress, 2, win10.Service, win10.EventLog

[I219.10.0.1..22000.HW]
Include = pci.inf
Needs = PciIoSpaceNotRequired.HW
AddReg = MSI.reg

;===============================================================================
;
;                Windows Server 2022 for 64-bit EXTENDED PLATFORMS
;
;===============================================================================
;-------------------------------------------------------------------------------
; Intel(R) Ethernet Connection I219
;-------------------------------------------------------------------------------

[I219.10.0...22000]
