;-----------------------------------------------------------------------------
; Driver "service" installation settings
;-----------------------------------------------------------------------------
[Service]
DisplayName    = %Service.Displayname%
ServiceType    = 1 ;%SERVICE_KERNEL_DRIVER%
StartType      = 3 ;%SERVICE_DEMAND_START%
ErrorControl   = 1 ;%SERVICE_ERROR_NORMAL%
ServiceBinary  = %12%\i40ea68.sys
LoadOrderGroup = NDIS
AddReg         = Service_AddReg

[Service_AddReg]
HKR,, BootFlags, 0x00010001, 0x1

;-----------------------------------------------------------------------------
; Event Log settings
;-----------------------------------------------------------------------------
[EventLog]
AddReg = AddEventLog

[CopyFiles]
i40ea68.sys,,,2

[CoInKPM.reg]
HKR,, CoInstallFlag, 0x00010001, 0x20680048

[CoInKPMNOSR.reg]
HKR,, CoInstallFlag, 0x00010001, 0x00680048

[MessageDll.CopyFiles]
i40eamsg.dll,,,2

[Uninstall.CopyFiles]
i40ea68.din,,,2

