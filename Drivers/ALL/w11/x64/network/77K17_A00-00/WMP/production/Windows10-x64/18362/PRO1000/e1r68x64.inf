;------------------------------------------------------------------------------
; Intel(R) I350 Gigabit Network Connection
;------------------------------------------------------------------------------
[E1521.10.0.1]
Characteristics    = 0x84 ; NCF_HAS_UI | NCF_PHYSICAL
BusType            = 5    ; PCI
Port1FunctionNumber = 0
DelReg             = Advanced.DelReg
DelReg             = WakeOnPort.DelReg
AddReg             = e1r.reg, TcpSeg.reg, ReduceSpeedOnPowerDown.reg, JumboPacket.reg
AddReg             = EnableWakeOnManagmentOnTCO.reg
AddReg             = Copper.reg, Copper1000.reg
AddReg             = Powermgmt.reg, WakeOnSlot.reg, WakeOnLink.reg
AddReg             = LLI.reg
AddReg             = RSS.reg, RSS8Q.reg
AddReg             = IntelANSVlanID.reg
AddReg             = EEE.reg
AddReg             = DMACoalescing.reg
AddReg             = ProtocolOffload.reg
AddReg             = CoInKSQuadLOM.reg
AddReg             = UninstallW2.reg
CopyFiles          = win10.CopyFiles, UninstallProg.CopyFiles, MessageDll.CopyFiles
*IfType            = 6     ; IF_TYPE_ETHERNET_CSMACD
*MediaType         = 0     ; NdisMedium802_3
*PhysicalMediaType = 14 ; NdisPhysicalMedium802_3

[E1521.10.0.1.Services]
AddService = e1rexpress, 2, win10.Service, win10.EventLog

[E1521.10.0.1.HW]
Include            = pci.inf
Needs              = PciSriovSupported.HW, PciIoSpaceNotRequired.HW
AddReg             = MSIX10.reg

